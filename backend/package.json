{
  "name": "tapiceria-lider-backend",
  "version": "1.0.0",
  "description": "API backend de Tapicería Líder",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "dotenv -e .env -- sequelize-cli db:migrate",
    "db:migrate:undo": "dotenv -e .env -- sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "dotenv -e .env -- sequelize-cli db:migrate:undo:all",
    "db:seed": "dotenv -e .env -- sequelize-cli db:seed:all",
    "db:seed:undo": "dotenv -e .env -- sequelize-cli db:seed:undo:all"
  },
  "keywords": [
    "tapiceria",
    "backend",
    "express",
    "postgresql",
    "sequelize"
  ],
  "author": "Joel / NexoDigital",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^11.0.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pdfkit": "^0.18.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "sequelize-cli": "^6.6.3"
  }
}
